# Copy to .env.local and fill in your values
# Project: savitz25 / Move Trust Hub

# Supabase — public (safe for browser + Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-anon-key>

# Supabase — server ONLY (never NEXT_PUBLIC_). Vercel: Production + Preview.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# Admin dashboard (/admin/quotes) — server ONLY
ADMIN_SECRET=<long-random-string>

# FMCSA QCMobile API web key — /verify-dot + automated directory refresh
# Register at https://mobile.fmcsa.dot.gov/QCDevsite/docs/api
FMCSA_WEB_KEY=

# Cron / GitHub Actions auth for /api/refresh/fmcsa (server ONLY)
CRON_SECRET=<long-random-string>

# BBB API — business profile lookup (register at https://api.bbb.org)
BBB_API_KEY=

# Optional bulk CSV fallback when API is unavailable
# Columns: slug,name,bbbId,businessId,rating,accredited,complaints,reviews,alerts
BBB_BULK_CSV_PATH=

# BBB refresh alerts (defaults to savitz25@gmail.com)
BBB_ALERT_EMAIL=savitz25@gmail.com

# FMCSA refresh alerts (defaults to savitz25@gmail.com)
FMCSA_ALERT_EMAIL=savitz25@gmail.com

# Optional RingCentral SMS alerts on critical FMCSA changes
FMCSA_ALERT_SMS_TO=
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_JWT=
RINGCENTRAL_FROM_NUMBER=
RINGCENTRAL_SERVER=https://platform.ringcentral.com

# Quote form emails (Resend)
RESEND_API_KEY=
RESEND_FROM=Move Trust Hub <notifications@movetrusthub.com>
QUOTE_TEAM_EMAIL=mhenry@amerisafemoving.com

# Brevo CRM + automation (Website Leads list)
BREVO_API_KEY=
BREVO_LIST_ID=7
