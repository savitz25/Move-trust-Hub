{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": [
    "iad1"
  ],
  "crons": [
    {
      "path": "/api/refresh/fmcsa?mode=incremental",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/refresh/fmcsa?mode=full",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/refresh/bbb?mode=incremental",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/refresh/bbb?mode=full",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/refresh/lenders?mode=incremental&limit=40",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/refresh/lenders?mode=full&limit=80",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/refresh/insurance-providers?mode=incremental&limit=40",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/refresh/insurance-providers?mode=full&limit=50",
      "schedule": "0 2 * * 0"
    }
  ],
  "headers": [
    {
      "source": "/companies",
      "headers": [
        {
          "key": "X-Trust-Hub",
          "value": "move"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/companies/:path*",
      "headers": [
        {
          "key": "X-Trust-Hub",
          "value": "move"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "X-Trust-Hub", "value": "move" },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=604800"
        },
        { "key": "CDN-Cache-Control", "value": "max-age=86400" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/local-movers/:path*",
      "headers": [
        { "key": "X-Trust-Hub", "value": "move" },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=3600"
        },
        { "key": "CDN-Cache-Control", "value": "max-age=60" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/:path((?!insurance|lender|admin|api|_next|local-movers).+)",
      "headers": [
        { "key": "X-Trust-Hub", "value": "move" },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=604800"
        },
        { "key": "CDN-Cache-Control", "value": "max-age=86400" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/image(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/sitemap-local/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/lender/:path((?!admin(?:/|$)).*)",
      "headers": [
        { "key": "X-Trust-Hub", "value": "lender" },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=604800"
        },
        { "key": "CDN-Cache-Control", "value": "max-age=86400" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/insurance/:path((?!admin(?:/|$)).*)",
      "headers": [
        { "key": "X-Trust-Hub", "value": "insurance" },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=604800"
        },
        { "key": "CDN-Cache-Control", "value": "max-age=86400" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(lender|insurance)/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css|woff2|ttf|otf|png|jpg|jpeg|webp|avif|svg|ico))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/companies",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=604800"
        },
        { "key": "CDN-Cache-Control", "value": "max-age=3600" }
      ]
    },
    {
      "source": "/api/reviews",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=604800"
        },
        { "key": "CDN-Cache-Control", "value": "max-age=3600" }
      ]
    },
    {
      "source": "/api/zip-distance",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/api/performance-flags",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/refresh/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/chat",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    },
    {
      "source": "/api/send-quote-email",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(insurance|lender)/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.lendertrusthub.com"
        }
      ],
      "destination": "https://www.movetrusthub.com/lender/:path*?from=lendertrusthub",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "lendertrusthub.com"
        }
      ],
      "destination": "https://www.movetrusthub.com/lender/:path*?from=lendertrusthub",
